# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_publishable_your-key-here

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# Embedding provider: ollama | anthropic | openrouter
EMBED_PROVIDER=ollama

# Generation LLM provider: ollama | anthropic | openrouter
LLM_PROVIDER=ollama

# Anthropic (needed if using anthropic for embedding or generation)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_EMBED_MODEL=voyage-3

# OpenRouter (needed if using openrouter for generation)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# Storage — where markdown files are saved on disk
KB_STORAGE_PATH=~/kb-store

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_CHANNEL_ID=C0123456789
SLACK_CROSSPOST_CHANNEL_ID=C9876543210

# Sanitization — set to true to enable LLM-based prompt injection scanning
SANITIZE_LLM_SCAN=false
